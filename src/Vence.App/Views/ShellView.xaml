<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Vence.App.Views.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:editorHost="using:Vence.EditorHost"
    xmlns:models="using:Vence.App.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="VenceSurfaceBrush" Color="#FFFCF7EE" />
        <SolidColorBrush x:Key="VencePanelBrush" Color="#FFF8F2E8" />
        <SolidColorBrush x:Key="VenceInkBrush" Color="#FF252A26" />
        <SolidColorBrush x:Key="VenceMutedBrush" Color="#FF6F746F" />
        <SolidColorBrush x:Key="VenceLineBrush" Color="#FFE3DACB" />
        <SolidColorBrush x:Key="VenceAccentBrush" Color="#FF355B4B" />
        <SolidColorBrush x:Key="VenceSelectedBrush" Color="#FFE8EEF0" />
        <Style x:Key="AiBubbleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="19" />
            <Setter Property="Background" Value="{StaticResource VenceSelectedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource VenceLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource VenceSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            MinHeight="56"
            Padding="18,0"
            BorderBrush="{StaticResource VenceLineBrush}"
            BorderThickness="0,0,0,1"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <TextBlock
                    FontFamily="Georgia"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource VenceAccentBrush}"
                    Text="V" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource VenceInkBrush}"
                    Text="Vence 文思" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock
                    FontSize="15"
                    Foreground="{StaticResource VenceInkBrush}"
                    Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="14"
                    Foreground="{StaticResource VenceAccentBrush}"
                    Glyph="&#xE73E;" />
                <TextBlock
                    FontSize="13"
                    Foreground="{StaticResource VenceMutedBrush}"
                    Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}" />
            </StackPanel>

            <CommandBar
                Grid.Column="2"
                Background="Transparent"
                DefaultLabelPosition="Right"
                IsOpen="False">
                <AppBarButton
                    x:Name="NewDocumentButton"
                    AutomationProperties.AutomationId="NewDocumentButton"
                    AutomationProperties.Name="新建文档"
                    Click="OnNewDocumentClick"
                    Icon="Page2"
                    IsEnabled="{x:Bind ViewModel.HasWorkspace, Mode=OneWay}"
                    Label="新建" />
                <AppBarButton
                    x:Name="OpenDocumentButton"
                    AutomationProperties.AutomationId="OpenDocumentButton"
                    AutomationProperties.Name="打开工作区"
                    Click="OnOpenWorkspaceClick"
                    Icon="OpenFile"
                    Label="打开" />
                <AppBarButton
                    x:Name="SaveDocumentButton"
                    AutomationProperties.AutomationId="SaveDocumentButton"
                    AutomationProperties.Name="保存文档"
                    Click="OnSaveDocumentClick"
                    Icon="Save"
                    IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}"
                    Label="保存" />
            </CommandBar>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="264" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="288" />
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Column="0"
                Padding="16"
                Background="{StaticResource VencePanelBrush}"
                BorderBrush="{StaticResource VenceLineBrush}"
                BorderThickness="0,0,1,0"
                RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <AutoSuggestBox
                    x:Name="DocumentSearchBox"
                    Grid.Row="0"
                    AutomationProperties.AutomationId="DocumentSearchBox"
                    AutomationProperties.Name="搜索文档"
                    PlaceholderText="搜索文档" />

                <TextBlock
                    Grid.Row="1"
                    Margin="2,6,0,0"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource VenceInkBrush}"
                    Text="工作区" />

                <ListView
                    x:Name="DocumentTreeList"
                    Grid.Row="2"
                    AutomationProperties.AutomationId="DocumentTreeList"
                    AutomationProperties.Name="文档文件树"
                    IsItemClickEnabled="True"
                    ItemClick="OnDocumentItemClick"
                    ItemsSource="{x:Bind ViewModel.Documents, Mode=OneWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DocumentListItem">
                            <Grid
                                MinHeight="32"
                                Padding="{x:Bind TreeMargin}"
                                ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="13"
                                    Foreground="{StaticResource VenceMutedBrush}"
                                    Glyph="{x:Bind TreeGlyph}" />
                                <TextBlock
                                    Grid.Column="1"
                                    MaxLines="1"
                                    Foreground="{StaticResource VenceInkBrush}"
                                    Text="{x:Bind Title}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid
                Grid.Column="1"
                Padding="28,20"
                RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CommandBar
                        Background="Transparent"
                        DefaultLabelPosition="Collapsed"
                        HorizontalAlignment="Left"
                        Visibility="{x:Bind ViewModel.EditorModeVisibility, Mode=OneWay}">
                        <AppBarButton
                            AutomationProperties.Name="加粗"
                            Click="OnEditorCommandClick"
                            Icon="Bold"
                            Label="加粗"
                            Tag="bold" />
                        <AppBarButton
                            AutomationProperties.Name="斜体"
                            Click="OnEditorCommandClick"
                            Icon="Italic"
                            Label="斜体"
                            Tag="italic" />
                        <AppBarButton
                            AutomationProperties.Name="插入链接"
                            Click="OnEditorCommandClick"
                            Icon="Link"
                            Label="链接"
                            Tag="link" />
                        <AppBarButton
                            AutomationProperties.Name="插入图片"
                            Click="OnEditorCommandClick"
                            Icon="Pictures"
                            Label="图片"
                            Tag="image" />
                    </CommandBar>

                    <ToggleButton
                        x:Name="ReaderModeButton"
                        Grid.Column="1"
                        MinWidth="112"
                        Padding="12,6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="ReaderModeButton"
                        AutomationProperties.Name="读者模式"
                        Click="OnReaderModeClick"
                        CornerRadius="16"
                        IsChecked="{x:Bind ViewModel.IsReaderMode, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="13"
                                Glyph="&#xE82D;" />
                            <TextBlock Text="{x:Bind ViewModel.ReaderModeLabel, Mode=OneWay}" />
                        </StackPanel>
                    </ToggleButton>
                </Grid>

                <Grid Grid.Row="1">
                    <Border
                        Margin="48,0"
                        Background="#FFFFFBF6"
                        BorderBrush="{StaticResource VenceLineBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <editorHost:EditorHostView
                            x:Name="MarkdownEditorHost"
                            AutomationProperties.AutomationId="MarkdownEditorHost"
                            AutomationProperties.Name="Markdown 编辑器宿主"
                            InitialMarkdown="{x:Bind ViewModel.CurrentMarkdown, Mode=OneWay}" />
                    </Border>

                    <StackPanel
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Visibility="{x:Bind ViewModel.ReaderModeVisibility, Mode=OneWay}">
                        <Button
                            AutomationProperties.Name="智能语法检查"
                            Click="OnReaderAssistantClick"
                            Style="{StaticResource AiBubbleButtonStyle}"
                            Tag="grammar"
                            ToolTipService.ToolTip="智能语法检查">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="15"
                                Foreground="{StaticResource VenceAccentBrush}"
                                Glyph="&#xE73E;" />
                        </Button>
                        <Button
                            AutomationProperties.Name="智能润色"
                            Click="OnReaderAssistantClick"
                            Style="{StaticResource AiBubbleButtonStyle}"
                            Tag="polish"
                            ToolTipService.ToolTip="智能润色">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="15"
                                Foreground="{StaticResource VenceAccentBrush}"
                                Glyph="&#xE790;" />
                        </Button>
                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Visibility="{x:Bind ViewModel.ReaderModeVisibility, Mode=OneWay}">
                        <Button
                            AutomationProperties.Name="智能补全"
                            Click="OnReaderAssistantClick"
                            Style="{StaticResource AiBubbleButtonStyle}"
                            Tag="completion"
                            ToolTipService.ToolTip="智能补全">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="15"
                                Foreground="{StaticResource VenceAccentBrush}"
                                Glyph="&#xE70F;" />
                        </Button>
                        <Button
                            AutomationProperties.Name="智能格式调整"
                            Click="OnReaderAssistantClick"
                            Style="{StaticResource AiBubbleButtonStyle}"
                            Tag="structure"
                            ToolTipService.ToolTip="智能格式调整">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="15"
                                Foreground="{StaticResource VenceAccentBrush}"
                                Glyph="&#xE8A5;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid
                Grid.Column="2"
                Padding="18,16"
                Background="{StaticResource VencePanelBrush}"
                BorderBrush="{StaticResource VenceLineBrush}"
                BorderThickness="1,0,0,0"
                RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource VenceInkBrush}"
                    Text="大纲" />

                <ListView
                    x:Name="OutlineList"
                    Grid.Row="1"
                    AutomationProperties.AutomationId="OutlineList"
                    AutomationProperties.Name="文档大纲"
                    IsItemClickEnabled="True"
                    ItemClick="OnOutlineItemClick"
                    ItemsSource="{x:Bind ViewModel.OutlineItems, Mode=OneWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:OutlineListItem">
                            <Grid MinHeight="30" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{StaticResource VenceMutedBrush}"
                                    Text="{x:Bind HeadingLabel}" />
                                <TextBlock
                                    Grid.Column="1"
                                    MaxLines="1"
                                    Foreground="{StaticResource VenceInkBrush}"
                                    Text="{x:Bind Title}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </Grid>
        </Grid>

        <Grid
            Grid.Row="2"
            Padding="18,0"
            BorderBrush="{StaticResource VenceLineBrush}"
            BorderThickness="0,1,0,0"
            ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{StaticResource VenceMutedBrush}"
                Text="{x:Bind ViewModel.WordCount, Mode=OneWay}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{StaticResource VenceMutedBrush}"
                Text="{x:Bind ViewModel.CharacterCount, Mode=OneWay}" />
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Center"
                Foreground="{StaticResource VenceMutedBrush}"
                Text="{x:Bind ViewModel.LineCount, Mode=OneWay}" />
        </Grid>
    </Grid>
</UserControl>
