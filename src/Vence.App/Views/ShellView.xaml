<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Vence.App.Views.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:editorHost="using:Vence.EditorHost"
    xmlns:models="using:Vence.App.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="VenceSurfaceBrush" Color="#FFFCF7EE" />
        <SolidColorBrush x:Key="VencePanelBrush" Color="#FFF8F2E8" />
        <SolidColorBrush x:Key="VenceInkBrush" Color="#FF252A26" />
        <SolidColorBrush x:Key="VenceMutedBrush" Color="#FF6F746F" />
        <SolidColorBrush x:Key="VenceLineBrush" Color="#FFE3DACB" />
        <SolidColorBrush x:Key="VenceAccentBrush" Color="#FF355B4B" />
        <SolidColorBrush x:Key="VenceSelectedBrush" Color="#FFE8EEF0" />
        <x:Double x:Key="VenceCornerRadius">8</x:Double>
    </UserControl.Resources>

    <Grid
        Background="{StaticResource VenceSurfaceBrush}"
        RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            MinHeight="56"
            Padding="18,0"
            BorderBrush="{StaticResource VenceLineBrush}"
            BorderThickness="0,0,0,1"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <TextBlock
                    FontFamily="Georgia"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource VenceAccentBrush}"
                    Text="V" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource VenceInkBrush}"
                    Text="Vence 文思" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock
                    FontSize="15"
                    Foreground="{StaticResource VenceInkBrush}"
                    Text="{x:Bind ViewModel.Title}" />
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    FontSize="14"
                    Foreground="{StaticResource VenceAccentBrush}"
                    Glyph="&#xE73E;" />
                <TextBlock
                    FontSize="13"
                    Foreground="{StaticResource VenceMutedBrush}"
                    Text="{x:Bind ViewModel.Subtitle}" />
            </StackPanel>

            <CommandBar
                Grid.Column="2"
                Background="Transparent"
                DefaultLabelPosition="Right"
                IsOpen="False">
                <AppBarButton
                    x:Name="NewDocumentButton"
                    AutomationProperties.AutomationId="NewDocumentButton"
                    AutomationProperties.Name="新建文档"
                    Icon="Page2"
                    Label="新建" />
                <AppBarButton
                    x:Name="OpenDocumentButton"
                    AutomationProperties.AutomationId="OpenDocumentButton"
                    AutomationProperties.Name="打开文档"
                    Icon="OpenFile"
                    Label="打开" />
                <AppBarButton
                    x:Name="SaveDocumentButton"
                    AutomationProperties.AutomationId="SaveDocumentButton"
                    AutomationProperties.Name="保存文档"
                    Icon="Save"
                    Label="保存" />
            </CommandBar>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="328" />
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Column="0"
                Padding="18,16"
                Background="{StaticResource VencePanelBrush}"
                BorderBrush="{StaticResource VenceLineBrush}"
                BorderThickness="0,0,1,0"
                RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="160" />
                </Grid.RowDefinitions>

                <AutoSuggestBox
                    x:Name="DocumentSearchBox"
                    Grid.Row="0"
                    AutomationProperties.AutomationId="DocumentSearchBox"
                    AutomationProperties.Name="搜索文档"
                    PlaceholderText="搜索文档" />

                <TextBlock
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource VenceInkBrush}"
                    Text="我的文档" />

                <ListView
                    x:Name="FolderList"
                    Grid.Row="2"
                    AutomationProperties.AutomationId="FolderList"
                    AutomationProperties.Name="文档文件夹"
                    IsItemClickEnabled="True"
                    ItemsSource="{x:Bind ViewModel.Folders, Mode=OneWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DocumentListItem">
                            <Grid
                                MinHeight="34"
                                ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Foreground="{StaticResource VenceMutedBrush}"
                                    Glyph="&#xE8B7;" />
                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{StaticResource VenceInkBrush}"
                                    Text="{x:Bind Title}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border
                    Grid.Row="3"
                    BorderBrush="{StaticResource VenceLineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid Padding="12">
                        <TextBlock
                            FontFamily="Georgia"
                            FontSize="15"
                            Foreground="{StaticResource VenceMutedBrush}"
                            Text="最近" />
                        <ListView
                            Margin="0,28,0,0"
                            AutomationProperties.AutomationId="RecentDocumentList"
                            AutomationProperties.Name="最近文档"
                            ItemsSource="{x:Bind ViewModel.Documents, Mode=OneWay}"
                            SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:DocumentListItem">
                                    <TextBlock
                                        MaxLines="1"
                                        Text="{x:Bind Title}"
                                        TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <Grid
                Grid.Column="1"
                Padding="34,24,34,20"
                RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="186" />
                </Grid.RowDefinitions>

                <CommandBar
                    Grid.Row="0"
                    Background="Transparent"
                    DefaultLabelPosition="Collapsed"
                    HorizontalAlignment="Stretch">
                    <AppBarButton
                        AutomationProperties.Name="加粗"
                        Icon="Bold"
                        Label="加粗" />
                    <AppBarButton
                        AutomationProperties.Name="斜体"
                        Icon="Italic"
                        Label="斜体" />
                    <AppBarButton
                        AutomationProperties.Name="插入链接"
                        Icon="Link"
                        Label="链接" />
                    <AppBarButton
                        AutomationProperties.Name="插入图片"
                        Icon="Pictures"
                        Label="图片" />
                </CommandBar>

                <Border
                    Grid.Row="1"
                    Background="#FFFFFBF6"
                    BorderBrush="{StaticResource VenceLineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <editorHost:EditorHostView
                        x:Name="MarkdownEditorHost"
                        AutomationProperties.AutomationId="MarkdownEditorHost"
                        AutomationProperties.Name="Markdown 编辑器宿主"
                        InitialMarkdown="{x:Bind ViewModel.InitialMarkdown}" />
                </Border>

                <Grid
                    Grid.Row="2"
                    ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="12"
                        BorderBrush="{StaticResource VenceLineBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid RowSpacing="9">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="大纲" />
                            <ListView
                                Grid.Row="1"
                                AutomationProperties.AutomationId="OutlineList"
                                AutomationProperties.Name="文档大纲"
                                ItemsSource="{x:Bind ViewModel.OutlineItems, Mode=OneWay}"
                                SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:OutlineListItem">
                                        <Grid MinHeight="28" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource VenceMutedBrush}"
                                                Text="{x:Bind HeadingLabel}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                MaxLines="1"
                                                Foreground="{StaticResource VenceInkBrush}"
                                                Text="{x:Bind Title}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="12"
                        BorderBrush="{StaticResource VenceLineBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{StaticResource VenceAccentBrush}"
                                    Text="Markdown 预览" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{StaticResource VenceMutedBrush}"
                                    Text="源码" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{StaticResource VenceMutedBrush}"
                                    Text="Mermaid 预览" />
                            </StackPanel>
                            <TextBox
                                Grid.Row="1"
                                Margin="0,12,0,0"
                                AcceptsReturn="True"
                                AutomationProperties.Name="预览源码"
                                BorderThickness="0"
                                IsReadOnly="True"
                                Text="graph LR&#x0a;A[Vence] --> B[历史]&#x0a;A --> C[艺术]&#x0a;A --> D[生活]" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid
                Grid.Column="2"
                Padding="18,16"
                Background="{StaticResource VencePanelBrush}"
                BorderBrush="{StaticResource VenceLineBrush}"
                BorderThickness="1,0,0,0"
                RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource VenceInkBrush}"
                    Text="文思，即泉涌" />

                <ListView
                    x:Name="AssistantList"
                    Grid.Row="1"
                    AutomationProperties.AutomationId="AssistantList"
                    AutomationProperties.Name="文思智能建议"
                    ItemsSource="{x:Bind ViewModel.AssistantItems, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:AssistantPanelItem">
                            <Grid
                                MinHeight="64"
                                Padding="0,7"
                                ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Width="30"
                                    Height="30"
                                    Background="{StaticResource VenceSelectedBrush}"
                                    CornerRadius="15">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Text="{x:Bind Icon}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Title}" />
                                    <TextBlock
                                        Foreground="{StaticResource VenceMutedBrush}"
                                        Text="{x:Bind Summary}" />
                                </StackPanel>
                                <FontIcon
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="12"
                                    Foreground="{StaticResource VenceMutedBrush}"
                                    Glyph="&#xE72A;" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border
                    Grid.Row="2"
                    Padding="12"
                    BorderBrush="{StaticResource VenceLineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="读文启思" />
                        <ListView
                            Grid.Row="1"
                            AutomationProperties.AutomationId="ReaderModeList"
                            AutomationProperties.Name="读者模式批注"
                            ItemsSource="{x:Bind ViewModel.ReaderNotes, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:AssistantPanelItem">
                                    <StackPanel Margin="0,4" Spacing="2">
                                        <TextBlock
                                            MaxLines="1"
                                            Text="{x:Bind Title}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource VenceMutedBrush}"
                                            Text="{x:Bind Summary}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBox
                            Grid.Row="2"
                            AutomationProperties.AutomationId="ReaderPromptBox"
                            AutomationProperties.Name="读者模式提问"
                            PlaceholderText="我也想说……" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid
            Grid.Row="2"
            Padding="18,0"
            BorderBrush="{StaticResource VenceLineBrush}"
            BorderThickness="0,1,0,0"
            ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{StaticResource VenceMutedBrush}"
                Text="{x:Bind ViewModel.WordCount}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{StaticResource VenceMutedBrush}"
                Text="{x:Bind ViewModel.CharacterCount}" />
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Center"
                Foreground="{StaticResource VenceMutedBrush}"
                Text="{x:Bind ViewModel.LineCount}" />
            <TextBlock
                Grid.Column="4"
                VerticalAlignment="Center"
                Foreground="{StaticResource VenceMutedBrush}"
                Text="主题：晨曦   |   字体大小：A  A  A   |   100%   |   Markdown" />
        </Grid>
    </Grid>
</UserControl>
